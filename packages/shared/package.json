{
  "name": "@paperclipai/shared",
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    }
  },

  "typesVersions": {
    "*": {
      "*": ["src/*"]
    }
  },

  "files": ["dist"],

  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },

  "dependencies": {
    "zod": "^3.24.2"
  },

  "devDependencies": {
    "typescript": "^5.7.3"
  }
}